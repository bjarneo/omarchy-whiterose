#!/bin/bash

set -euo pipefail

shell_json="$HOME/.config/omarchy/shell.json"
command="${1:-status}"

usage() {
  cat <<'EOF'
Usage: scripts/whiterose-network-backend <status|fix-nm>

Whiterose.network is NetworkManager-only. This helper reports or repairs
NetworkManager availability; it no longer switches widget backends.
EOF
}

if (($# > 1)); then
  echo "too many arguments" >&2
  usage >&2
  exit 1
fi

case "$command" in
  status|fix-nm)
    ;;
  -h|--help)
    usage
    exit 0
    ;;
  auto|nm|iwd|iw)
    echo "backend '$command' is obsolete; whiterose.network uses NetworkManager only" >&2
    usage >&2
    exit 1
    ;;
  *)
    echo "unknown argument: $command" >&2
    usage >&2
    exit 1
    ;;
esac

networkmanager_ok() {
  command -v nmcli >/dev/null 2>&1 || return 1
  nmcli general status >/dev/null 2>&1 || return 1
}

print_stale_backend_status() {
  [[ -f "$shell_json" ]] || return 0
  python3 - "$shell_json" <<'PY'
import json
import sys

path = sys.argv[1]
with open(path) as f:
    config = json.load(f)

layout = config.get("bar", {}).get("layout", {})
for section in ("left", "center", "right"):
    for entry in layout.get(section, []) or []:
        if isinstance(entry, dict) and entry.get("id") == "whiterose.network":
            if "backend" in entry:
                print("stale shell.json backend key: ignored")
            raise SystemExit(0)
PY
}

fix_networkmanager() {
  if networkmanager_ok; then
    return 0
  fi

  if ! command -v systemctl >/dev/null 2>&1; then
    return 1
  fi

  if systemctl is-active --quiet NetworkManager.service 2>/dev/null; then
    networkmanager_ok
    return
  fi

  echo "attempting to enable/start NetworkManager.service"
  sudo systemctl enable --now NetworkManager.service >/dev/null
  nmcli radio wifi on >/dev/null 2>&1 || true
  networkmanager_ok
}

print_status() {
  if command -v nmcli >/dev/null 2>&1; then
    if nmcli general status >/dev/null 2>&1; then
      echo "NetworkManager: ok"
    else
      echo "NetworkManager: nmcli present, daemon not responding"
    fi
  else
    echo "NetworkManager: nmcli missing"
  fi

  echo "whiterose.network: NetworkManager-only"
  print_stale_backend_status
}

case "$command" in
  status)
    print_status
    ;;
  fix-nm)
    if fix_networkmanager; then
      echo "NetworkManager is available; whiterose.network can use it"
    else
      echo "NetworkManager fix failed" >&2
      exit 1
    fi
    ;;
esac
