{
  "schemaVersion": 1,
  "id": "whiterose.network",
  "name": "Whiterose Network",
  "version": "1.0.0",
  "author": "bjarneo",
  "license": "MIT",
  "description": "Connection state glyph with SSID tooltip. Click opens a network TUI.",
  "kinds": ["bar-widget"],
  "entryPoints": { "barWidget": "Widget.qml" },
  "barWidget": {
    "displayName": "Whiterose network",
    "description": "Wi-Fi and ethernet state",
    "category": "Network",
    "allowMultiple": false,
    "defaults": { "onClick": "omarchy-launch-floating-terminal-with-presentation nmtui" },
    "schema": [
      { "key": "onClick", "type": "string", "label": "Click command" }
    ]
  }
}
