{
  "schemaVersion": 1,
  "id": "whiterose.network",
  "name": "Whiterose Network",
  "version": "1.0.0",
  "author": "bjarneo",
  "license": "MIT",
  "description": "Connection state glyph with a keyboard-driven Wi-Fi popout.",
  "kinds": ["bar-widget"],
  "entryPoints": { "barWidget": "Widget.qml" },
  "barWidget": {
    "displayName": "Whiterose network",
    "description": "Wi-Fi and ethernet state with NetworkManager/iwd picker",
    "category": "Network",
    "allowMultiple": false,
    "defaults": { "backend": "auto" },
    "schema": [
      { "key": "backend", "type": "string", "label": "Backend", "default": "auto", "description": "auto, nm, iwd, or iw" }
    ]
  }
}
